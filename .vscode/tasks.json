{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "启动后端 (FastAPI)",
            "type": "shell",
            "command": "uv",
            "args": [
                "run",
                "uvicorn",
                "app.main:app",
                "--reload",
                "--host",
                "127.0.0.1",
                "--port",
                "8000"
            ],
            "options": {
                "cwd": "${workspaceFolder}/demo-app/backend"
            },
            "problemMatcher": [],
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "group": "backend"
            }
        },
        {
            "label": "启动前端 (Vite)",
            "type": "shell",
            "command": "pnpm",
            "args": [
                "dev"
            ],
            "options": {
                "cwd": "${workspaceFolder}/demo-app/frontend"
            },
            "problemMatcher": [],
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "group": "frontend"
            }
        },
        {
            "label": "⚡ 一键启动前后端",
            "dependsOn": [
                "启动后端 (FastAPI)",
                "启动前端 (Vite)"
            ],
            "dependsOrder": "parallel",
            "problemMatcher": []
        },
        {
            "label": "数据库迁移 (Alembic)",
            "type": "shell",
            "command": "uv",
            "args": [
                "run",
                "alembic",
                "upgrade",
                "head"
            ],
            "options": {
                "cwd": "${workspaceFolder}/demo-app/backend"
            },
            "problemMatcher": []
        },
        {
            "label": "安装后端依赖",
            "type": "shell",
            "command": "uv",
            "args": [
                "sync"
            ],
            "options": {
                "cwd": "${workspaceFolder}/demo-app/backend"
            },
            "problemMatcher": []
        },
        {
            "label": "🔧 首次初始化（安装依赖 + 迁移）",
            "dependsOn": [
                "安装后端依赖",
                "数据库迁移 (Alembic)"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        }
    ]
}
