{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug FastAPI (DiagDoctor)",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--host", "127.0.0.1",
                "--port", "8001"
            ],
            // 必须指向 backend 目录，uvicorn 才能找到 app.main 模块
            "cwd": "${workspaceFolder}/demo-app/backend",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/demo-app/backend"
            },
            "justMyCode": true,
            "console": "integratedTerminal"
        }
    ]
}