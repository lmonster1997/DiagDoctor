# ============================================================
# TaskFlow Demo App — Environment Variables (example)
# ============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ============================================================

# --- Application ---
APP_NAME=TaskFlow API
APP_VERSION=0.1.0
DEBUG=false

# --- Database (PostgreSQL) ---
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/taskflow

# --- JWT Authentication ---
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-in-production-use-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- OpenTelemetry (Observability) ---
# Endpoint for the OTel Collector (gRPC)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=demo-backend

# --- CORS (allowed origins for the frontend) ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
